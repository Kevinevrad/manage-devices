model Logiciel {

    id Int @id @default(autoincrement())
    nom String  // Ex: "Office 365", "Adobe CC", "Windows 11 Pro",
    editeur String 
    cleLicence String @unique
    dateAchat DateTime @default(now())
    dateExp DateTime
    typeLicence String @default("Groupe") // Unique
    
    // Relation : Un logiciel peut être installé sur plusieurs équipements (et inversement)
    affectations LicencesSurEquipement[]

}
model LicencesSurEquipement {
    equipementId Int
    logicielId Int 
    installeLe DateTime @default(now())

    equipement Equipement @relation(fields: [equipementId], references: [id], onDelete: Cascade)
    logiciel Logiciel @relation(fields: [logicielId], references: [id], onDelete: Cascade)

    @@id([equipementId, logicielId]) 
    // Clé primaire composite
}
