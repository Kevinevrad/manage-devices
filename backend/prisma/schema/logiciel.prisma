model Logiciel {

    id Int @id @default(autoincrement())
    nom String  // Ex: "Office 365", "Adobe CC", "Windows 11 Pro",
    editeur String 
    cleLicence String @unique
    dateAchat DateTime @default(now())
    dateExp DateTime
    typeLicence String @default("Groupe") // Unique
    
    // Relation : Un logiciel peut être installé sur plusieurs équipements (et inversement)
    affectations LicencesSurEquipement[]

}
